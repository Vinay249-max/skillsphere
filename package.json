{
  "name": "skillsphere-api",
  "version": "1.0.0",
  "description": "SkillSphere — RESTful API for online learning platform",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "mocha 'test/**/*.test.js' --timeout 10000 --exit",
    "test:coverage": "nyc --reporter=text --reporter=lcov mocha 'test/**/*.test.js' --timeout 10000 --exit",
    "test:unit": "mocha 'test/courses.test.js' --timeout 10000 --exit",
    "test:integration": "mocha 'test/users.integration.test.js' --timeout 10000 --exit"
  },
  "keywords": ["skillsphere", "api", "elearning", "express"],
  "author": "SkillSphere Team",
  "license": "MIT",
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "chai": "^4.4.1",
    "mocha": "^10.4.0",
    "nodemon": "^3.1.0",
    "nyc": "^15.1.0",
    "supertest": "^7.0.0"
  }
}
